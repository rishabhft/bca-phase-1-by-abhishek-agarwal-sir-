// Problem 3 -- Nested if-else statement 
#include <iostream>
using namespace std;

int main() {
    int age;
    cin >> age;
    
    if(age >= 18) {
        if(age >= 50) {
            cout << " Senior citizen eligible for vote...";
        } else {
            cout << " eligible for vote...";
        }
    } else {
        if(age < 0) {
            cout << "enter a valid age number...";
        } else {
            cout << "Not eligible for vote...";
        }
    }
}
